            paths:
              - path: /
                pathType: Prefix
                service:
                  port: 7878
        tls:
        - secretName: radarr-tls
          hosts:
          - radarr.example.com
    podSecurityContext:
      runAsUser: 568
      runAsGroup: 568
      fsGroup: 568
  rtorrent-flood.yaml: |
    # on the first launch we need to chown the media files from our pvc shared-media for this we need to startup rtorrent
    # as root first, so at the bottom of this rtorent-flood.yaml change all podSecurityContext ids to 0
    # then uncomment this initContainers block
    # initContainers:
    #   take-data-dir-plex:
    #     image: alpine
    #     command:
    #       - chown
    #       - -R
    #       - 568:568
    #       - /downloads
    #     volumeMounts:
    #       - name: downloads
    #         mountPath: /downloads
    service:
      bittorrent:
        enabled: true
        type: ClusterIP
        ports:
          bittorrent:
            enabled: true
            port: 6881
            protocol: TCP
            targetPort: 6881
    persistence:
      config:
        mountPath: "/config"
        enabled: true
        accessMode: "ReadWriteOnce"
        size: "5Gi"
        storageClass: "freenas-iscsi-csi"
        readOnly: false
      downloads:
        enabled: true
        mountPath: "/downloads"
        accessMode: "ReadWriteMany"
        size: "1000Gi"
        storageClass: "freenas-nfs-csi"
        existingClaim: "shared-media"
    ingress:
      main:
        annotations:
          kubernetes.io/ingress.class: "nginx"
          cert-manager.io/cluster-issuer: "letsencrypt-staging"
          external-dns.alpha.kubernetes.io/hostname: "rtorrent.example.com."
          external-dns.alpha.kubernetes.io/cloudflare-proxied: "false"
          external-dns.alpha.kubernetes.io/ttl: "120"
          nginx.ingress.kubernetes.io/auth-url: http://authelia.authelia.svc.cluster.local/api/verify
          nginx.ingress.kubernetes.io/auth-signin: https://auth.example.com
        enabled: true
        hosts:
          - host: rtorrent.example.com
            paths:
              - path: /
                pathType: Prefix
                service:
                  port: 3000
        tls:
        - secretName: rtorrent-tls
          hosts:
          - rtorrent.example.com
    podSecurityContext:
      runAsUser: 568
      runAsGroup: 568
      fsGroup: 568
