  vaultwarden.yaml: |
    ingress:
      main:
        annotations:
          kubernetes.io/ingress.class: "nginx"
          cert-manager.io/cluster-issuer: "letsencrypt-staging"
          external-dns.alpha.kubernetes.io/hostname: "vaultwarden.example.com."
          external-dns.alpha.kubernetes.io/cloudflare-proxied: "false"
          external-dns.alpha.kubernetes.io/ttl: "120"
          nginx.ingress.kubernetes.io/auth-url: http://authelia.authelia.svc.cluster.local/api/verify
          nginx.ingress.kubernetes.io/auth-signin: https://auth.example.com
        enabled: true
        hosts:
          - host: vaultwarden.example.com
            paths:
              - path: /
                pathType: Prefix
                service:
                  port: 80
              - path: /notifications/hub/negotiate
                pathType: Prefix
                service:
                  port: 80
              - path: /notifications/hub
                pathType: Prefix
                service:
                  port: 3012
        tls:
        - secretName: vaultwarden-tls
          hosts:
          - vaultwarden.example.com
    persistence:
      config:
        enabled: true
        readOnly: false
        storageClass: freenas-iscsi-csi
    postgresql:
      enabled: true
      postgresqlUsername: ime
      postgresqlPassword: homelab
      postgresqlDatabase: ime
      persistence:
        enabled: true
        storageClass: "freenas-iscsi-csi"
        accessModes:
          - ReadWriteOnce
  whoami.yaml: |
    service:
      service.externalTrafficPolicy: "Local"
    ingress:
      annotations:
        cert-manager.io/cluster-issuer: "letsencrypt-staging"
        external-dns.alpha.kubernetes.io/hostname: "whoami.example.com."
        external-dns.alpha.kubernetes.io/cloudflare-proxied: "false"
        external-dns.alpha.kubernetes.io/ttl: "120"
        #nginx.ingress.kubernetes.io/auth-url: http://authelia.authelia.svc.cluster.local/api/verify
        #nginx.ingress.kubernetes.io/auth-signin: https://auth.example.com
      enabled: 'true'
      ingressClassName: "nginx"
      pathType: ImplementationSpecific
      hosts:
        - host: whoami.example.com
          paths:
          - "/"
      tls:
      - secretName: whoami-tls
        hosts:
          - whoami.example.com
