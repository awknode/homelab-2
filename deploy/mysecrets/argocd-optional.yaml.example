apiVersion: v1
kind: Secret
metadata:
  name: helm-values
  namespace: argocd
stringData:
  authelia.yaml: |
    secret:
      storageEncryptionKey:
        key: STORAGE_ENCRYPTION_KEY
        value: "storage_you_must_generate_a_random_string_of_more_than_twenty_chars_and_configure_this"
        filename: STORAGE_ENCRYPTION_KEY
      sessionEncryptionKey:
        key: SESSION_ENCRYPTION_KEY
        value: "session_you_must_generate_a_random_string_of_more_than_twenty_chars_and_configure_this"
        filename: SESSION_ENCRYPTION_KEY
      ldap:
        key: LDAP_PASSWORD
        value: "homelab"
        filename: LDAP_PASSWORD
      smtp:
        key: SMTP_PASSWORD
        value: "homelab"
        filename: SMTP_PASSWORD
    persistence:
      enabled: true
      mountPath: "/config"
      storageClass: "freenas-iscsi-csi"
      accessMode: "ReadWriteMany"
    domain: example.com
    pod:
      replicas: 3
      kind: StatefulSet
      revisionHistoryLimit: 2
    configMap:
      log:
        level: debug
      authentication_backend:
        ldap:
          enabled: false
          implementation: custom
          url: ldap://openldap-openldap-stack-ha.openldap.svc.cluster.local
          timeout: 10s
          start_tls: false
          tls:
            server_name: openldap-openldap-stack-ha.openldap.svc.cluster.local
            skip_verify: true
            minimum_version: TLS1.2
          base_dn: dc=ldap,dc=example,dc=com
          username_attribute: uid
          additional_users_dn: ou=User
          users_filter: (&({username_attribute}={input})(objectClass=inetOrgPerson))
          additional_groups_dn: ou=Group
          group_name_attribute: cn
          groups_filter: (&(member={dn})(objectClass=groupOfNames))
          mail_attribute: mail
          display_name_attribute: displayName
          user: "cn=admin,dc=ldap,dc=example,dc=com"
        file:
          enabled: true
          password:
            algorithm: sha512
            iterations: 100000
          path: /config/users/users_database.yml
      default_redirection_url: "https://hub.example.com"
      session:
        redis:
          enabled: false
        domain: example.com
        expiration: 3600
        inactivity: 300
      storage:
        encryption_key: "you_must_generate_a_random_string_of_more_than_twenty_chars_and_configure_this"
        local:
          enabled: true
        postgres:
          enabled: false
      notifier:
        filesystem:
          enabled: false
          filename: /config/notification.txt
        smtp:
          enabled: true
          enabledSecret: true
          host: mail.example.me
          port: 587
          timeout: 5s
          username: auth@example.me
          sender: auth@example.me
          identifier: mail.example.me
          subject: "[Authelia] {title}"
          startup_check_address: auth@example.me
          disable_require_tls: false
          disable_html_emails: false
          tls:
            server_name: "mail.example.me"
            skip_verify: false
            minimum_version: TLS1.2
      identity_providers:
        oidc:
          enabled: false
      theme: dark
      access_control:
        default_policy: deny
        rules:
        - domain: "*.example.com"
          policy: bypass
          networks:
            - 10.42.0.0/16
        - domain: ['lidarr.example.com','sonarr.example.com', 'overseerr.example.com', 'radarr.example.com', 'ha.example.com', 'plex.example.com', 'nextcloud.example.com', 'ha.example.com', 'vaultwarden.example.com']
          policy: bypass
          resources:
            - "^/api.*"
            - "^/signalr.*"
        - domain: 'rtorrent.example.com'
          policy: bypass
          resources:
            - "^/RPC2.*"

        - domain: ['lidarr.example.com', 'ldap-admin.example.com', 'ha.example.com', 'prowlarr.example.com', 'sonarr.example.com', 'radarr.example.com', 'rtorrent.example.com', 'nzbget.example.com']
          policy: two_factor
          subject: 
          - 'group:admins'

        - domain: ['whoami.example.com', 'harbor.example.com', 'ltb-passwd.example.com', 'plex.example.com', 'overseerr.example.com', 'nextcloud.example.com', 'photos.example.com', 'vaultwarden.example.com']
          policy: two_factor
          subject:
          - 'group:users'

        - domain: ['hub.example.com']
          policy: bypass
    ingress:
      annotations:
        kubernetes.io/ingress.class: "nginx"
        cert-manager.io/cluster-issuer: "letsencrypt-staging"
        external-dns.alpha.kubernetes.io/hostname: "auth.example.com."
        external-dns.alpha.kubernetes.io/cloudflare-proxied: "false"
        external-dns.alpha.kubernetes.io/ttl: "120"
      enabled: true
      hosts:
        - host: auth.example.com
          paths:
            - path: /
              pathType: Prefix
              service:
                port: 80
      tls:
        enabled: true
        secret: auth-tls
  democratic_iscsi.yaml: |
    csiDriver:
      # should be globally unique for a given cluster
      name: "org.democratic-csi.iscsi"

    # add note here about volume expansion requirements
    storageClasses:
    - name: freenas-iscsi-csi
      defaultClass: false
      reclaimPolicy: Retain
      volumeBindingMode: Immediate
      allowVolumeExpansion: true
      parameters:
        # for block-based storage can be ext3, ext4, xfs
        fsType: ext4

      mountOptions: []
      secrets:
        provisioner-secret:
        controller-publish-secret:
        node-stage-secret:
        node-publish-secret:
        controller-expand-secret:

    driver:
      config:
        driver: freenas-iscsi
        instance_id:
        httpConnection:
          protocol: http
          host: 172.16.137.108
          port: 80
          username: root
          password: "homelab"
          allowInsecure: true
          apiVersion: 2
        sshConnection:
          host: 172.16.137.108
          port: 22
          username: root
          # use either password or key
          password: "homelab"
        zfs:
          # the example below is useful for TrueNAS 12
          cli:
            paths:
              zfs: /usr/local/sbin/zfs
              zpool: /usr/local/sbin/zpool
              sudo: /usr/local/bin/sudo
              chroot: /usr/sbin/chroot
          # total volume name (zvol/<datasetParentName>/<pvc name>) length cannot exceed 63 chars
          # https://www.ixsystems.com/documentation/freenas/11.2-U5/storage.html#zfs-zvol-config-opts-tab
          # standard volume naming overhead is 46 chars
          # datasetParentName should therefore be 17 chars or less
          datasetParentName: a1/k8s/iscsi/v
          detachedSnapshotsDatasetParentName: a1/k8s/iscsi/s
          # "" (inherit), lz4, gzip-9, etc
          zvolCompression:
          # "" (inherit), on, off, verify
          zvolDedup:
          zvolEnableReservation: false
          # 512, 1K, 2K, 4K, 8K, 16K, 64K, 128K default is 16K
          zvolBlocksize:
        iscsi:
          targetPortal: "172.16.137.108:3260"
          targetPortals: []
          # leave empty to omit usage of -I with iscsiadm
          interface:
          namePrefix: csi-
          nameSuffix: "-cluster"
          # add as many as needed
          targetGroups:
            # get the correct ID from the "portal" section in the UI
            - targetGroupPortalGroup: 1
              # get the correct ID from the "initiators" section in the UI
              targetGroupInitiatorGroup: 1
              # None, CHAP, or CHAP Mutual
              targetGroupAuthType: None
              # get the correct ID from the "Authorized Access" section of the UI
              # only required if using Chap
              targetGroupAuthGroup:
          extentInsecureTpc: true
          extentXenCompat: false
          extentDisablePhysicalBlocksize: true
          # 512, 1024, 2048, or 4096,
          extentBlocksize: 4096
          # "" (let FreeNAS decide, currently defaults to SSD), Unknown, SSD, 5400, 7200, 10000, 15000
          extentRpm: "7200"
          # 0-100 (0 == ignore)
          extentAvailThreshold: 0
    volumeSnapshotClasses:
    - name: freenas-iscsi-csi
      annotations:
        k10.kasten.io/is-snapshot-class: "true"
  democratic_nfs.yaml: |
    csiDriver:
      # should be globally unique for a given cluster
      name: "org.democratic-csi.nfs"

    storageClasses:
    - name: freenas-nfs-csi
      defaultClass: false
      reclaimPolicy: Retain
      volumeBindingMode: Immediate
      allowVolumeExpansion: true
      parameters:
        fsType: nfs

      mountOptions:
      - noatime
      - nfsvers=4
      secrets:
        provisioner-secret:
        controller-publish-secret:
        node-stage-secret:
        node-publish-secret:
        controller-expand-secret:

    driver:
      config:
        driver: freenas-nfs
        instance_id:
        httpConnection:
          protocol: http
          host: 172.16.137.108
          port: 80
          username: root
          password: "homelab"
          allowInsecure: true
        sshConnection:
          host: 172.16.137.108
          port: 22
          username: root
          # use either password or key
          password: "homelab"
            #      privateKey: |
            #        -----BEGIN RSA PRIVATE KEY-----
            #        ...
            #        -----END RSA PRIVATE KEY-----
        zfs:
          datasetParentName: a1/k8s/nfs/v
          detachedSnapshotsDatasetParentName: a1/k8s/nfs/s
          datasetEnableQuotas: true
          datasetEnableReservation: false
          datasetPermissionsMode: "0777"
          datasetPermissionsUser: root
          datasetPermissionsGroup: wheel
        nfs:
          shareHost: 172.16.137.108
          shareAlldirs: false
          shareAllowedHosts: []
          shareAllowedNetworks: []
          shareMaprootUser: root
          shareMaprootGroup: wheel
          shareMapallUser: ""
          shareMapallGroup: ""
  harbor.yaml: |
    core:
      tls:
        existingSecret: harbor-ingress
    service:
      type: ingress
      tls:
        existingSecret: harbor-ingress
        commonName: harbor.example.com
    internalTLS:
      enabled: false
    harborAdminPassword: "homelab"
    externalURL: https://harbor.example.com
    global:
      storageClass: freenas-iscsi-csi
    notary:
      enabled: false
    ingress:
      certManager: true
      enabled: true
      pathType: ImplementationSpecific
      hosts:
        core: harbor.example.com
      controller: default
      annotations:
        kubernetes.io/ingress.class: "nginx"
        cert-manager.io/cluster-issuer: "letsencrypt-staging"
        external-dns.alpha.kubernetes.io/hostname: "harbor.example.com."
        external-dns.alpha.kubernetes.io/cloudflare-proxied: "false"
        external-dns.alpha.kubernetes.io/ttl: "120"
        ingress.kubernetes.io/proxy-body-size: '0'
        nginx.ingress.kubernetes.io/auth-url: http://authelia.authelia.svc.cluster.local/api/verify
        nginx.ingress.kubernetes.io/auth-signin: https://auth.example.com
  heimdall.yaml: |
    ingress:
      main:
        annotations:
          kubernetes.io/ingress.class: "nginx"
          cert-manager.io/cluster-issuer: "letsencrypt-staging"
          external-dns.alpha.kubernetes.io/hostname: "hub.example.com."
          external-dns.alpha.kubernetes.io/cloudflare-proxied: "false"
          external-dns.alpha.kubernetes.io/ttl: "120"
        enabled: true
        hosts:
          - host: hub.example.com
            paths:
              - path: /
                pathType: Prefix
                service:
                  port: 80
        tls:
        - secretName: hub-tls
          hosts:
          - hub.example.com
    persistence:
      config:
        enabled: true
        storageClass: freenas-iscsi-csi
        readOnly: false
  home_assistant.yaml: |
    http:
      server_host: 0.0.0.0
      ip_ban_enabled: true
      login_attempts_threshold: 5
      use_x_forwarded_for: true
      trusted_proxies:
      # Pod CIDR
      - 10.42.0.0/16
      # Node CIDR
      - 172.16.137.0/24
    ingress:
      main:
        enabled: true
        annotations:
          kubernetes.io/ingress.class: "nginx"
          cert-manager.io/cluster-issuer: "letsencrypt-staging"
          external-dns.alpha.kubernetes.io/hostname: "ha.example.com."
          external-dns.alpha.kubernetes.io/cloudflare-proxied: "false"
          external-dns.alpha.kubernetes.io/ttl: "120"
          nginx.ingress.kubernetes.io/auth-url: http://authelia.authelia.svc.cluster.local/api/verify
          nginx.ingress.kubernetes.io/auth-signin: https://auth.example.com
          nginx.org/websocket-services: home-assistant
        hosts:
          - host: ha.example.com
            paths:
              - path: /
                pathType: Prefix
                service:
                  port: 8123
        tls:
        - secretName: ha-tls
          hosts:
          - ha.example.com
    mariadb:
      enabled: true
      architecture: standalone
      auth:
        database: home-assistant
        username: home-assistant
        password: homelab
        rootPassword: homelab
      primary:
        persistence:
          enabled: true
          storageClass: "freenas-iscsi-csi"
    persistence:
      config:
        enabled: "true"
        storageClass: "freenas-iscsi-csi"
        size: "1Gi"
        readOnly: false
  kasten.yaml: |
    global:
      persistence:
        storageClass: "freenas-iscsi-csi"
  kuma.yaml: |
    ingress:
      annotations:
        kubernetes.io/ingress.class: "nginx"
        cert-manager.io/cluster-issuer: "letsencrypt-staging"
        external-dns.alpha.kubernetes.io/hostname: "uptime.example.com."
        external-dns.alpha.kubernetes.io/cloudflare-proxied: "false"
        external-dns.alpha.kubernetes.io/ttl: "120"
      enabled: true
      hosts:
        - host: uptime.example.com
          paths:
            - path: /
              pathType: Prefix
              service:
                port: 80
      tls:
      - secretName: uptime-tls
        hosts:
        - uptime.example.com
    persistence:
      enabled: "true"
      storageClass: "freenas-iscsi-csi"
      size: "1Gi"
  lidarr.yaml: |
    persistence:
      config:
        enabled: true
        accessMode: "ReadWriteOnce"
        storageClass: "freenas-iscsi-csi"
        size: "5Gi"
        readOnly: false
      media:
        enabled: true
        accessMode: "ReadWriteOnce"
        size: "1000Gi"
        storageClass: "freenas-nfs-csi"
        existingClaim: "shared-media"
        mountPath: "/media"
    ingress:
      main:
        annotations:
          kubernetes.io/ingress.class: "nginx"
          cert-manager.io/cluster-issuer: "letsencrypt-staging"
          external-dns.alpha.kubernetes.io/hostname: "lidarr.example.com."
          external-dns.alpha.kubernetes.io/cloudflare-proxied: "false"
          external-dns.alpha.kubernetes.io/ttl: "120"
          nginx.ingress.kubernetes.io/auth-response-headers: Remote-User,Remote-Name,Remote-Groups,Remote-Email
          nginx.ingress.kubernetes.io/auth-snippet: |
            proxy_set_header X-Forwarded-Method $request_method;
          nginx.ingress.kubernetes.io/configuration-snippet: |
            proxy_set_header X-Forwarded-Method $request_method;
          nginx.ingress.kubernetes.io/auth-url: http://authelia.authelia.svc.cluster.local/api/verify
          nginx.ingress.kubernetes.io/auth-signin: https://auth.example.com
        enabled: true
        hosts:
          - host: lidarr.example.com
            paths:
              - path: /
                pathType: Prefix
                service:
                  port: 8686
        tls:
        - secretName: lidarr-tls
          hosts:
          - lidarr.example.com
    podSecurityContext:
      runAsUser: 568
      runAsGroup: 568
      fsGroup: 568
  nextcloud.yaml: |
    mariadb:
      enabled: true
      auth:
        database: ncloud
        username: ncloud
        password: homelab
      architecture: standalone
      primary:
        persistence:
          enabled: false
          storageClass: "freenas-iscsi-csi"
          accessMode: ReadWriteOnce
          size: 1Gi
    nextcloud:
      host: nextcloud.example.com
      configs:
        trusted_domains.config.php: |-
          <?php
          $CONFIG = [
            'overwriteprotocol' => 'https',
            'trusted_domains' => [
              0 => 'localhost',
              1 => 'nextcloud.kube.home',
              2 => 'nextcloud.example.com'
            ]
          ];
    ingress:
      annotations:
        kubernetes.io/ingress.class: "nginx"
        cert-manager.io/cluster-issuer: "letsencrypt-staging"
        external-dns.alpha.kubernetes.io/hostname: "nextcloud.example.com."
        external-dns.alpha.kubernetes.io/cloudflare-proxied: "false"
        external-dns.alpha.kubernetes.io/ttl: "120"
        nginx.ingress.kubernetes.io/auth-url: http://authelia.authelia.svc.cluster.local/api/verify
        nginx.ingress.kubernetes.io/auth-signin: https://auth.example.com
        nginx.ingress.kubernetes.io/server-snippet: |-
          server_tokens off;
          proxy_hide_header X-Powered-By;
          
          rewrite ^/.well-known/webfinger /public.php?service=webfinger last;
          rewrite ^/.well-known/host-meta /public.php?service=host-meta last;
          rewrite ^/.well-known/host-meta.json /public.php?service=host-meta-json;

          location = /.well-known/carddav {
            return 301 $scheme://$host/remote.php/dav;
          }
          location = /.well-known/caldav {
            return 301 $scheme://$host/remote.php/dav;
          }
          location = /robots.txt {
            allow all;
            log_not_found off;
            access_log off;
          }
          location ~ ^/(?:build|tests|config|lib|3rdparty|templates|data)/ {
            deny all;
          }
          location ~ ^/(?:autotest|occ|issue|indie|db_|console) {
            deny all;
          }
      enabled: true
      hosts:
        - host: nextcloud.example.com
          paths:
            - path: /
              pathType: Prefix
              service:
                port: 8080
      tls:
      - secretName: nextcloud-tls
        hosts:
        - nextcloud.example.com

    persistence:
      # Nextcloud Data (/var/www/html)
      enabled: true
      annotations: {}
      storageClass: "freenas-iscsi-csi"
      # existingClaim:
      accessMode: ReadWriteOnce
      size: 8Gi

      ## Use an additional pvc for the data directory rather than a subpath of the default PVC
      ## Useful to store data on a different storageClass (e.g. on slower disks)
      nextcloudData:
        enabled: true
        annotations: {}
        storageClass: "freenas-iscsi-csi"
        # existingClaim:
        accessMode: ReadWriteOnce
        size: 500Gi
  nzbget.yaml: |
    persistence:
      config:
        enabled: true
        accessMode: "ReadWriteOnce"
        storageClass: "freenas-iscsi-csi"
        size: "5Gi"
        readOnly: false
      media:
        enabled: true
        accessMode: "ReadWriteOnce"
        size: "50Gi"
        storageClass: "freenas-iscsi-csi"
        existingClaim: "shared-media"
      downloads:
        enabled: true
        accessMode: "ReadWriteOnce"
        size: "50Gi"
        storageClass: "freenas-iscsi-csi"
    ingress:
      main:
        annotations:
          kubernetes.io/ingress.class: "nginx"
          cert-manager.io/cluster-issuer: "letsencrypt-staging"
          external-dns.alpha.kubernetes.io/hostname: "nzbget.example.com."
          external-dns.alpha.kubernetes.io/cloudflare-proxied: "false"
          external-dns.alpha.kubernetes.io/ttl: "120"
          nginx.ingress.kubernetes.io/auth-url: http://authelia.authelia.svc.cluster.local/api/verify
          nginx.ingress.kubernetes.io/auth-signin: https://auth.example.com
        enabled: true
        hosts:
          - host: nzbget.example.com
            paths:
              - path: /
                pathType: Prefix
                service:
                  port: 6789
        tls:
        - secretName: radarr-tls
          hosts:
          - nzbget.example.com
    podSecurityContext:
      runAsUser: 911
      runAsGroup: 911
      fsGroup: 911
  openldap.yaml: |
    service:
      type: NodePort
    env:
      LDAP_DOMAIN: "ldap.example.com"
      LDAP_ORGANISATION: "loeken"
      LDAP_TLS: "false"
      LDAP_TLS_ENFORCE: "false"
      LDAP_REMOVE_CONFIG_AFTER_SETUP: "true"
      LDAP_READONLY_USER: "false"
      LDAP_READONLY_USER_USERNAME: readonly
      LDAP_READONLY_USER_PASSWORD: homelab
    replicaCount: 1
    adminPassword: homelab
    configPassword: homelab
    logLevel: debug
    persistence:
      storageClass: "freenas-iscsi-csi"
      size: 1Gi
    ltb-passwd:
      ingress:
        enabled: true
        hosts:
          - ltb-passwd.example.com
        annotations:
          kubernetes.io/ingress.class: "nginx"
          cert-manager.io/cluster-issuer: "letsencrypt-staging"
          external-dns.alpha.kubernetes.io/hostname: "ltb-passwd.example.com."
          external-dns.alpha.kubernetes.io/cloudflare-proxied: "false"
          external-dns.alpha.kubernetes.io/ttl: "120"
          nginx.ingress.kubernetes.io/auth-url: http://authelia.authelia.svc.cluster.local/api/verify
          nginx.ingress.kubernetes.io/auth-signin: https://auth.example.com
        tls:
          - secretName: ltb-passwd-tls
            hosts:
              - ltb-passwd.example.com
      ldap:
        server: ldap://openldap-openldap-stack-ha
        searchBase: dc=ldap,dc=example,dc=com
        bindDN: cn=admin,dc=ldap,dc=example,dc=com
        bindPWKey: LDAP_ADMIN_PASSWORD

    phpldapadmin:
      ingress:
        annotations:
          kubernetes.io/ingress.class: "nginx"
          cert-manager.io/cluster-issuer: "letsencrypt-staging"
          external-dns.alpha.kubernetes.io/hostname: "ldap-admin.example.com."
          external-dns.alpha.kubernetes.io/cloudflare-proxied: "false"
          external-dns.alpha.kubernetes.io/ttl: "120"
          nginx.ingress.kubernetes.io/auth-url: http://authelia.authelia.svc.cluster.local/api/verify
          nginx.ingress.kubernetes.io/auth-signin: https://auth.example.com
        hosts:
          - ldap-admin.example.com
        tls:
          - secretName: phpldapadmin-tls
            hosts:
            - ldap-admin.example.com
      env:
        PHPLDAPADMIN_LDAP_HOSTS: "ldap://openldap-openldap-stack-ha:389"
        PHPLDAPADMIN_HTTPS: "false"
        PHPLDAPADMIN_TRUST_PROXY_SSL: "true" 
  overseerr.yaml: |
    persistence:
      config:
        type: "pvc"
        enabled: true
        mountPath: /app/config
        accessMode: "ReadWriteOnce"
        size: "5Gi"
        storageClass: "freenas-iscsi-csi"
        readOnly: false
    ingress:
      main:
        annotations:
          kubernetes.io/ingress.class: "nginx"
          cert-manager.io/cluster-issuer: "letsencrypt-staging"
          external-dns.alpha.kubernetes.io/hostname: "overseerr.example.com."
          external-dns.alpha.kubernetes.io/cloudflare-proxied: "false"
          external-dns.alpha.kubernetes.io/ttl: "120"
          nginx.ingress.kubernetes.io/auth-url: http://authelia.authelia.svc.cluster.local/api/verify
          nginx.ingress.kubernetes.io/auth-signin: https://auth.example.com
        enabled: true
        hosts:
          - host: overseerr.example.com
            paths:
              - path: /
                pathType: Prefix
                service:
                  port: 5055
        tls:
        - secretName: overseerr-tls
          hosts:
          - overseerr.example.com
    podSecurityContext:
      runAsUser: 568
      runAsGroup: 568
      fsGroup: 568
  plex.yaml: |
    persistence:
      config:
        mountPath: "/config"
        enabled: true
        accessMode: "ReadWriteOnce"
        size: "5Gi"
        storageClass: "freenas-iscsi-csi"
        readOnly: false
      transcode:
        enabled: true
        mountPath: "/transcode"
        size: "10Gi"
        storageClass: "local-path"
        accessMode: "ReadWriteOnce"
      media:
        enabled: true
        accessMode: "ReadWriteMany"
        size: "1000Gi"
        storageClass: "freenas-nfs-csi"
        existingClaim: "shared-media"
    ingress:
      main:
        annotations:
          nginx.org/location-snippets: |
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection upgrade;
          kubernetes.io/ingress.class: "nginx"
          cert-manager.io/cluster-issuer: "letsencrypt-staging"
          external-dns.alpha.kubernetes.io/hostname: "plex.example.com."
          external-dns.alpha.kubernetes.io/cloudflare-proxied: "false"
          external-dns.alpha.kubernetes.io/ttl: "120"
          nginx.ingress.kubernetes.io/auth-url: http://authelia.authelia.svc.cluster.local/api/verify
          nginx.ingress.kubernetes.io/auth-signin: https://auth.example.com
        enabled: true
        hosts:
          - host: plex.example.com
            paths:
              - path: /
                pathType: Prefix
                service:
                  port: 32400
        tls:
        - secretName: plexserver-tls
          hosts:
          - plex.example.com
    podSecurityContext:
      runAsUser: 568
      runAsGroup: 568
      fsGroup: 568
